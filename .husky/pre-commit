#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run lint-staged on staged files
echo "🔍 Running linter on staged files..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ Linting failed. Aborting commit."
  exit 1
fi

# # Run unit and integration tests with coverage
# # echo "🧪 Running Jest unit and integration tests..."
# # npm run test:unit
# # if [ $? -ne 0 ]; then
# #   echo "❌ Unit tests failed. Aborting commit."
# #   exit 1
# # fi

# # npm run test:integration
# # if [ $? -ne 0 ]; then
# #   echo "❌ Integration tests failed. Aborting commit."
# #   exit 1
# # fi

# Run Postman collections if present
if compgen -G "postman/collections/*" > /dev/null; then
  echo "📬 Running Postman collections..."
  for collection in postman/collections; do
    if [ -f "$collection" ]; then
      echo "  → Running: $(basename "$collection")"
      postman collection run "$collection"
      if [ $? -ne 0 ]; then
        echo "❌ Postman collection failed: $collection"
        exit 1
      fi
    fi
  done
  echo "✅ All Postman collections passed!"
else
  echo "ℹ️ No Postman collections found, skipping Postman tests."
fi

echo "✅ All pre-commit checks passed!"
